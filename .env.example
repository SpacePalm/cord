# Copy to .env and fill in the values:
#   cp .env.example .env

# Database (PostgreSQL)
POSTGRES_DB=cord
POSTGRES_USER=cord
POSTGRES_PASSWORD=cord

# Backend
CORD_JWT_SECRET=change-me-in-production
CORD_JWT_EXPIRE_MINUTES=1440

CORD_ADMIN_USERNAME=admin
CORD_ADMIN_EMAIL=admin@example.com
CORD_ADMIN_PASSWORD=change-me

# LiveKit (voice/video)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Public IP of the server (for WebRTC ICE candidates, use 127.0.0.1 for local dev)
SERVER_IP=127.0.0.1
# Public URL for browser WebSocket connection (default: ws://localhost:7880)
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# Log level: debug, info, warn, error
LIVEKIT_LOG_LEVEL=info

# S3 / Object Storage (optional)
# When enabled, s3fs mounts the S3 bucket as /app/media inside the container.
# Works with MinIO, AWS S3, Yandex Cloud Storage, etc.
CORD_S3_ENABLED=false
CORD_S3_BUCKET=cord-media
CORD_S3_ACCESS_KEY=
CORD_S3_SECRET_KEY=
CORD_S3_REGION=us-east-1
CORD_S3_ENDPOINT_URL=        # empty = AWS S3; MinIO example: http://minio:9000
